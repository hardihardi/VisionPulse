# VisionPulse Environment Variables

# Frontend (Next.js)
# URL of your Flask backend API.
# On Render, this will be your .onrender.com URL.
# On local development, use http://localhost:5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Backend (Flask)
# Set to 'production' or 'development'
FLASK_ENV=development
PORT=5000
